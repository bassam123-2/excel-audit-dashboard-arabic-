# Django runtime
DJANGO_SETTINGS_MODULE=django_project.settings.local
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Asia/Riyadh

# HTTP port used by run scripts
EXCEL_ARABIC_PORT=8765
EXCEL_ARABIC_LOGO=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=excel_arabic
MYSQL_USER=root
MYSQL_PASSWORD=

# SMTP (optional — legal-text email feature)
# EXCEL_ARABIC_SMTP_HOST=smtp.example.com
# EXCEL_ARABIC_SMTP_PORT=587
# EXCEL_ARABIC_SMTP_USER=your-user@example.com
# EXCEL_ARABIC_SMTP_PASSWORD=your-app-password
# EXCEL_ARABIC_SMTP_FROM=your-user@example.com
# EXCEL_ARABIC_SMTP_USE_TLS=1
# EXCEL_ARABIC_SMTP_DISPLAY_NAME=ادارة الالتزام
