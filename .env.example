# Copy to .env or smtp.env in the project root (never commit real values).
# Environment variables override values in these files.

# --- Server ---
EXCEL_ARABIC_PORT=8765
# EXCEL_ARABIC_HOST=127.0.0.1
# EXCEL_ARABIC_LOGO=C:\path\to\logo.png

# --- SMTP (optional — legal-text email feature) ---
# EXCEL_ARABIC_SMTP_HOST=smtp.example.com
# EXCEL_ARABIC_SMTP_PORT=587
# EXCEL_ARABIC_SMTP_USER=your-user@example.com
# EXCEL_ARABIC_SMTP_PASSWORD=your-app-password
# EXCEL_ARABIC_SMTP_FROM=your-user@example.com
# EXCEL_ARABIC_SMTP_USE_TLS=1
# EXCEL_ARABIC_SMTP_DISPLAY_NAME=ادارة الالتزام
